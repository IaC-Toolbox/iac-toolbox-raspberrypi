// Scrape systemd journal
loki.source.journal "systemd" {
  max_age       = "24h"
  forward_to    = [loki.write.local.receiver]
  labels        = {
    job  = "systemd",
    host = "{{ ansible_hostname }}",
  }
}

// Discover Docker containers
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

// Filter out infrastructure containers
discovery.relabel "containers" {
  targets = discovery.docker.containers.targets

  // Drop infra containers - we don't want Loki logging about itself
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(loki|alloy|grafana|prometheus)$"
    action        = "drop"
  }

  // Extract container name without leading slash
  rule {
    source_labels = ["__meta_docker_container_name"]
    regex         = "/(.*)"
    target_label  = "container_name"
  }

  // Add log stream (stdout/stderr) as label
  rule {
    source_labels = ["__meta_docker_container_log_stream"]
    target_label  = "stream"
  }
}

// Scrape Docker container logs (only non-infra containers)
loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.containers.output
  forward_to = [loki.process.uvicorn.receiver]
  labels = {
    job  = "docker",
    host = "{{ ansible_hostname }}",
  }
}

// Parse log levels from application logs (e.g., uvicorn, Python apps)
loki.process "uvicorn" {
  forward_to = [loki.write.local.receiver]

  // Extract log level from common Python logging formats
  // Matches: "INFO:", "ERROR:", "WARNING:", "DEBUG:", "CRITICAL:"
  stage.regex {
    expression = "^(?P<level>INFO|WARNING|ERROR|CRITICAL|DEBUG):\\s+.*"
  }

  // Add log level as a label for filtering
  stage.labels {
    values = {
      level = "level",
    }
  }
}

// Scrape /var/log files
local.file_match "system_logs" {
  path_targets = [
    {
      __address__ = "localhost",
      __path__    = "/var/log/syslog",
      job         = "syslog",
      host        = "{{ ansible_hostname }}",
    },
    {
      __address__ = "localhost",
      __path__    = "/var/log/auth.log",
      job         = "auth",
      host        = "{{ ansible_hostname }}",
    },
  ]
}

loki.source.file "system_logs" {
  targets    = local.file_match.system_logs.targets
  forward_to = [loki.write.local.receiver]
}

// Send all logs to Loki
loki.write "local" {
  endpoint {
    url = "http://loki:{{ loki.port }}/loki/api/v1/push"
  }
}
