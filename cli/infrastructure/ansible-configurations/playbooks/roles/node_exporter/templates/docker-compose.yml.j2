services:
  node-exporter:
    container_name: node-exporter
    image: prom/node-exporter:v{{ node_exporter_version }}
    restart: always
    ports:
      - "{{ node_exporter_port }}:{{ node_exporter_port }}"
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /:/rootfs:ro
    command:
      - "--path.procfs=/host/proc"
      - "--path.sysfs=/host/sys"
      - "--path.rootfs=/rootfs"
      - "--web.listen-address=:{{ node_exporter_port }}"
    networks:
      - monitoring

networks:
  monitoring:
    name: monitoring
    external: true
