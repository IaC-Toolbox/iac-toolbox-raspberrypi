// Scrape Node Exporter and tag metrics with this device's hostname
prometheus.scrape "node_exporter" {
  targets = [{
    __address__ = "{{ alloy_node_exporter_host }}:{{ node_exporter_port }}",
    instance    = "{{ grafana_alloy.instance_name | default(ansible_hostname) }}",
    job         = "node_exporter",
  }]
  scrape_interval = "15s"
  forward_to = [prometheus.remote_write.platform.receiver]
}

// Push metrics to the central Prometheus instance on the platform
prometheus.remote_write "platform" {
  endpoint {
    url = "{{ alloy_remote_write_url }}"
  }
}
