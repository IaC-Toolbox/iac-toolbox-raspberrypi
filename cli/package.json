{
  "name": "iac-toolbox-cli",
  "version": "1.0.0",
  "description": "Infrastructure as Code Toolbox CLI",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^22.14.0",
    "pnpm": "^10.33.0"
  },
  "bin": {
    "iac": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "tsc --noEmit && eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "pnpm run lint -- --fix",
    "lint-fix": "pnpm run lint -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --ci --coverage --maxWorkers=2"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ink": "^5.1.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "react": "^18.3.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IaC-Toolbox/iac-toolbox-cli.git"
  },
  "license": "ISC",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testing-library/react": "^14.3.1",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.12",
    "@typescript-eslint/eslint-plugin": "7.1.1",
    "@typescript-eslint/parser": "7.1.1",
    "cli-testing-library": "^2.0.2",
    "eslint": "8.56.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-react": "7.33.2",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-react-refresh": "0.4.14",
    "ink-testing-library": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "prettier": "3.2.5",
    "ts-jest": "^29.4.9",
    "tsx": "^4.20.6",
    "typescript": "5.4.2"
  }
}
