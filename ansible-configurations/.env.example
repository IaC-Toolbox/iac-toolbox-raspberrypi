# ============================================
# Raspberry Pi Infrastructure Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================
# Raspberry Pi Connection
# ============================================
RPI_HOST=raspberrypi.local          # Hostname or IP address
RPI_USER=pi                          # SSH username
RPI_SSH_KEY=~/.ssh/id_ed25519       # Path to SSH private key

# ============================================
# GitHub Actions Runner
# ============================================
# Get token from: GitHub Repo > Settings > Actions > Runners > New self-hosted runner
GITHUB_REPO_URL=https://github.com/username/repo
GITHUB_RUNNER_TOKEN=ABCDEFGH123456...  # Time-limited token (regenerate when expired)
RUNNER_VERSION=2.315.0                  # GitHub runner version
RUNNER_LABELS=rpi,arm64,docker          # Custom labels for workflow targeting

# ============================================
# Application Secrets (Examples)
# ============================================
# These will be encrypted in secrets.yml and deployed to /etc/raspberrypi.env

# OpenAI API
OPENAI_API_KEY=sk-...

# Database
DATABASE_URL=postgres://user:pass@host:5432/db

# Generic API Secret
API_SECRET=your-secret-here

# Add your own secrets as needed
# MY_CUSTOM_SECRET=value
