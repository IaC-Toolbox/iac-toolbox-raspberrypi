# ============================================
# Raspberry Pi Infrastructure Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ============================================
# Raspberry Pi Connection
# ============================================
RPI_HOST=raspberrypi.local          # Hostname or IP address
RPI_USER=pi                          # SSH username
RPI_SSH_KEY=~/.ssh/id_ed25519       # Path to SSH private key

# ============================================
# GitHub Actions Runner
# ============================================
# Get token from: GitHub Repo > Settings > Actions > Runners > New self-hosted runner
GITHUB_REPO_URL=https://github.com/username/repo
GITHUB_RUNNER_TOKEN=ABCDEFGH123456...  # Time-limited token (regenerate when expired)
RUNNER_VERSION=2.315.0                  # GitHub runner version
RUNNER_LABELS=rpi,arm64,docker          # Custom labels for workflow targeting

# ============================================
# Grafana Configuration
# ============================================
GRAFANA_ADMIN_USER=admin                # Grafana admin username
GRAFANA_ADMIN_PASSWORD=changeme123      # Generate with: openssl rand -base64 32

# ============================================
# Grafana Alerts Configuration
# ============================================
ALERT_EMAIL=your-email@example.com      # Email for alert notifications (fallback if PagerDuty not configured)
# Note: Alert thresholds are hardcoded in terraform/grafana-alerts/alerts.tf
#       System: CPU: 5% (testing), Memory: 90%, Disk: 80%
#       Hardware: Offline: 5m, Temperature: 75°C
#       SMTP configuration done manually in Grafana UI if email delivery needed

# ============================================
# PagerDuty Integration (Optional)
# ============================================
# If configured, replaces email notifications with PagerDuty incidents
# Get API token from: PagerDuty > Integrations > API Access Keys > Create New API Key
# Permissions required: Read/Write
PAGERDUTY_TOKEN=                         # PagerDuty API token (leave empty to use email)
PAGERDUTY_SERVICE_REGION=us              # "us" or "eu" (check your PagerDuty URL)
PAGERDUTY_USER_EMAIL=your-email@example.com  # Your PagerDuty account email

# How to get PagerDuty API token:
# 1. Sign up at https://www.pagerduty.com (free tier available)
# 2. Go to Integrations > API Access Keys
# 3. Click "Create New API Key"
# 4. Name: "Terraform", Permissions: "Read/Write"
# 5. Copy the token (you won't see it again!)

# ============================================
# Application Secrets (Examples)
# ============================================
# These will be encrypted in secrets.yml and deployed to /etc/raspberrypi.env

# OpenAI API
OPENAI_API_KEY=sk-...

# Database
DATABASE_URL=postgres://user:pass@host:5432/db

# Generic API Secret
API_SECRET=your-secret-here

# Add your own secrets as needed
# MY_CUSTOM_SECRET=value
