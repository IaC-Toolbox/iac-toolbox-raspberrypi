// Scrape Node Exporter and tag metrics with this device's hostname
prometheus.scrape "node_exporter" {
  targets = [{
    __address__ = "{{ alloy_docker_host }}:{{ node_exporter_port }}",
    instance    = "{{ grafana_alloy.instance_name | default(ansible_hostname) }}",
    job         = "node_exporter",
  }]
  scrape_interval = "15s"
  forward_to     = [prometheus.relabel.node_exporter_compat.receiver]
}

// ── Scrape cAdvisor (on the monitoring Docker network) ───────────────────
prometheus.scrape "cadvisor" {
  targets = [{
    __address__ = "{{ alloy_docker_host }}:{{ cadvisor_port }}",   // reachable by container name on the network
    instance    = "{{ grafana_alloy.instance_name | default(ansible_hostname) }}",
    job         = "cadvisor",
  }]
  scrape_interval = "15s"
  forward_to      = [prometheus.remote_write.platform.receiver]
}


// Push metrics to the central Prometheus instance on the platform
prometheus.remote_write "platform" {
  endpoint {
    url = "{{ grafana_alloy.alloy_remote_write_url }}"
  }
}

// Rename metrics for dashboard compatibility.
// On macOS, Node Exporter uses different memory metric names than Linux.
// These rules rename them to the Linux names expected by Node Exporter Full (dashboard ID 1860).
prometheus.relabel "node_exporter_compat" {
  forward_to = [prometheus.remote_write.platform.receiver]

{% if ansible_facts['system'] == 'Darwin' %}
  // node_memory_MemTotal_bytes: total physical RAM
  rule {
    source_labels = ["__name__"]
    regex         = "node_memory_total_bytes"
    target_label  = "__name__"
    replacement   = "node_memory_MemTotal_bytes"
  }
  // node_memory_MemAvailable_bytes: approximate — macOS "free" only.
  // Active + wired + inactive pages will appear as "used", which slightly overstates usage.
  rule {
    source_labels = ["__name__"]
    regex         = "node_memory_free_bytes"
    target_label  = "__name__"
    replacement   = "node_memory_MemAvailable_bytes"
  }
  // node_memory_SwapTotal_bytes: rename to Linux name for dashboard compatibility.
  // SwapFree is computed on the Prometheus side via a recording rule (swap_total - swap_used).
  rule {
    source_labels = ["__name__"]
    regex         = "node_memory_swap_total_bytes"
    target_label  = "__name__"
    replacement   = "node_memory_SwapTotal_bytes"
  }
{% endif %}
}
